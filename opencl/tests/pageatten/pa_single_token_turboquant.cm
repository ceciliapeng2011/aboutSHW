// Dedicated TurboQuant decoding kernel file.
// This file is independent from pa_single_token.cm and keeps only code paths:
//   KV_CACHE_COMPRESSION == 0
//   USE_LSC_BLOCK_2D_DESC == 1

#if XE_ARCH < 2
#error "cm_sdpa_2nd_turboquant requires XE_ARCH>=2"
#endif

#if TQ_BITS != 4
#error "cm_sdpa_2nd_turboquant currently supports TQ_BITS==4"
#endif

#define REG_N 16
#define USE_LSC_BLOCK_2D_DESC 1

#define SystolicDepth 8
#define RepeatCount 1
#define VNNI_WIDTH 2
#define REG_K (SystolicDepth * VNNI_WIDTH)
#define REG_M RepeatCount
#define KV_PARTITION_STEP_NUM  (KV_PARTITION_SIZE / KV_STEP)

#define KV_SCALE_ZP_SIZE 0

extern "C" _GENX_MAIN_ void cm_sdpa_2nd_turboquant(
	half* query [[type("svmptr_t")]],
	uint8_t* key [[type("svmptr_t")]],
	half* value [[type("svmptr_t")]],
	int* past_lens [[type("svmptr_t")]],
	int* block_indices [[type("svmptr_t")]],
	int* block_indices_begins [[type("svmptr_t")]],
	int* subsequence_begins [[type("svmptr_t")]],
	float* output [[type("svmptr_t")]],
	float* lse [[type("svmptr_t")]],
	const half* tq_q_t [[type("svmptr_t")]],
	const half* tq_centroids [[type("svmptr_t")]],
	int q_len// 1
	) {
	const uint seq_idx = cm_global_id(0);
	const uint kv_head_num_idx = cm_global_id(1) / Q_head_chunks_per_kv_head;
	const uint head_num_idx = cm_global_id(1) * Q_head_chunk_size;
	const uint wg_thread_id = cm_global_id(2);
	const uint kv_partition_num = cm_group_count(2);
	const uint kv_partition_idx = cm_group_id(2);

	const uint kv_len = past_lens[seq_idx] + 1;
	constexpr uint K_PACKED_BYTES = (HEAD_SIZE * TQ_BITS + 7) / 8;
	constexpr uint K_TOKEN_BYTES = K_PACKED_BYTES + 2;

	const uint start_block_idx = block_indices_begins[seq_idx] + kv_partition_idx * (KV_PARTITION_SIZE / KV_BLOCK_SIZE);

	if (kv_partition_idx * KV_PARTITION_SIZE > kv_len) {
		return;
	}
	const uint total_blocks_num = (kv_len + KV_BLOCK_SIZE - 1) / KV_BLOCK_SIZE;
	constexpr uint kv_pitch = HEAD_SIZE * sizeof(half);
	// [TurboQuant LUT preload]
	// Load centroid table once per thread: used by packed-index dequantization.
	vector<float, (1 << TQ_BITS)> centroid_tbl;
	{
		vector<half, (1 << TQ_BITS)> centroid_h;
		cm_svm_block_read<half, (1 << TQ_BITS)>((svmptr_t)tq_centroids, centroid_h);
		centroid_tbl = centroid_h;
	}

	// [Load Q]
	// Q layout: [seq, head, dim] chunk for current (kv_head, q_head_chunk).
	const uint qo_offset = (seq_idx * HEADS_NUM * q_len + head_num_idx) * HEAD_SIZE;
	matrix<half, Q_head_chunk_size, HEAD_SIZE> Qmat = 0;
	cm_svm_block_read<half, Q_head_chunk_size * HEAD_SIZE>((svmptr_t)(query + qo_offset), Qmat.format<half>());

	// [Compute rotated Q]
	// Apply TurboQuant rotation in-kernel: Qrot = Q * Q_T.
	matrix<half, Q_head_chunk_size, HEAD_SIZE> Qrot = 0;
	#pragma unroll
	for (int qi = 0; qi < Q_head_chunk_size; qi++) {
		#pragma unroll
		for (int d = 0; d < HEAD_SIZE; d++) {
			float acc = 0.0f;
			#pragma unroll
			for (int j = 0; j < HEAD_SIZE; j++) {
				acc += (float)Qmat[qi][j] * (float)tq_q_t[j * HEAD_SIZE + d];
			}
			Qrot[qi][d] = (half)acc;
		}
	}

	constexpr uint per_v_block_element_num = KV_BLOCK_SIZE * KV_HEADS_NUM * (HEAD_SIZE + KV_SCALE_ZP_SIZE);
	constexpr uint per_k_block_element_num = KV_BLOCK_SIZE * KV_HEADS_NUM * K_TOKEN_BYTES;
	uint block_num = KV_PARTITION_SIZE / KV_BLOCK_SIZE;

	uint leftover_size = 0;
	if (kv_partition_idx == kv_partition_num - 1) {
		leftover_size = (kv_len - KV_PARTITION_SIZE * kv_partition_idx) % KV_PARTITION_SIZE;
	}
	if (block_num > total_blocks_num - start_block_idx) {
		block_num = total_blocks_num - start_block_idx;
	}

	// [Q * K^T accumulator]
	// rS stores attention logits for current KV partition.
	matrix<float, Q_head_chunk_size, REG_M * KV_PARTITION_STEP_NUM * REG_N> rS = 0;

	#pragma unroll
	for (uint block_idx = 0, ki = 0; block_idx < block_num; block_idx++) {
		// [Load K metadata]
		// K is TurboQuant packed: per-token packed 4-bit indices + fp16 norm.
		uint blk_indices = block_indices[start_block_idx + block_idx];
		uint k_base_offset = blk_indices * per_k_block_element_num + kv_head_num_idx * (per_k_block_element_num / KV_HEADS_NUM);
		const half* k_norm_base = reinterpret_cast<const half*>(key + k_base_offset + KV_BLOCK_SIZE * K_PACKED_BYTES);

		uint kv_pos_end = KV_BLOCK_SIZE;
		if (block_idx == block_num - 1 && leftover_size > 0) {
			kv_pos_end = leftover_size % KV_BLOCK_SIZE;
			if (kv_pos_end == 0) kv_pos_end = KV_BLOCK_SIZE;
		}

		for (int kv_pos = 0; kv_pos < kv_pos_end; kv_pos += KV_STEP, ki++) {
			#pragma unroll
			for (int ri = 0; ri < HEAD_SIZE / REG_K; ri++) {
				// [Dequantize K tile]
				// Rebuild fp16 Kt tile from packed indices via centroid lookup.
				matrix<half, REG_K, REG_N> Kt = 0;
				const int packed_base = ri * (REG_K / 2);

				#pragma unroll
				for (int n = 0; n < REG_N; n++) {
					int token_in_block = kv_pos + n;
					if (token_in_block >= kv_pos_end) {
						continue;
					}

					const uint token_packed_off = k_base_offset + token_in_block * K_PACKED_BYTES + packed_base;
					vector<uchar, REG_K / 2> packed8 = 0;
					cm_svm_block_read<uchar, REG_K / 2>((svmptr_t)(key + token_packed_off), packed8);
					float knorm = (float)k_norm_base[token_in_block];

					#pragma unroll
					for (int p = 0; p < REG_K / 2; p++) {
						uchar packed = packed8[p];
						int idx0 = (int)(packed & 0x0f);
						int idx1 = (int)(packed >> 4);
						float k0 = centroid_tbl[idx0] * knorm;
						float k1 = centroid_tbl[idx1] * knorm;
						// [QJL correction]
						// Apply per-token norm (scale) after centroid lookup.
						Kt[p * 2][n] = (half)k0;
						Kt[p * 2 + 1][n] = (half)k1;
					}
				}

				// [Q * K^T]
				// Use DPAS (XMX) on rotated Q and dequantized K tile.
				matrix<half, Q_head_chunk_size, REG_K> Qmat_data = Qrot.select<Q_head_chunk_size,1,REG_K,1>(0, ri * REG_K);
				matrix<float, Q_head_chunk_size, REG_N> rS_data = 0;
				rS_data = cm_dpas<CM_PRECISION_HF, CM_PRECISION_HF, SystolicDepth, Q_head_chunk_size>(
							rS_data.format<float>(),
							Kt.format<int32_t>(),
							Qmat_data.format<int32_t>());
				rS.select<Q_head_chunk_size, 1, REG_N, 1>(0, ki * REG_N) += rS_data;
			}
		}
	}

	// [Softmax]
	// Convert logits rS -> probabilities Pmat; track partition-local lse/sum.
	vector<float, Q_head_chunk_size> cur_sum = 0.0f;
	vector<float, Q_head_chunk_size> cur_lse = 0.0f;
	matrix<half, Q_head_chunk_size, KV_PARTITION_STEP_NUM * REG_M * REG_N> Pmat = 0;

	#pragma unroll
	for (int qi = 0; qi < Q_head_chunk_size; qi++) {
		auto rS_slice = rS[qi].format<float, KV_PARTITION_STEP_NUM, REG_N>();
		rS_slice = cm_mul<float>(rS_slice, (float)SCALE_FACTOR);

		if (leftover_size > 0) {
			auto Svec = rS_slice.format<float>();
			for (int i = leftover_size; i < KV_PARTITION_STEP_NUM * REG_N; i++) {
				Svec[i] = -3e38f;
			}
		}

		constexpr float log2e = 1.4426950408889634f;
		constexpr float loge2 = 0.6931471805599453f;

		auto rSv = rS_slice.format<float>();
		float row_max = rSv[0];
		for (int r = 1; r < rSv.n_elems(); r++) {
			row_max = cm_max<float>(row_max, rSv[r]);
		}

		vector<float, KV_PARTITION_STEP_NUM * REG_N> rS_exp_temp = cm_exp((rSv - row_max) * log2e);
		Pmat[qi].format<half, KV_PARTITION_STEP_NUM * REG_M, REG_N>() = rS_exp_temp;

		cur_lse[qi] = cm_sum<float>(rS_exp_temp.format<float>());
		cur_lse[qi] = cm_log<float>(cur_lse[qi]) * loge2 + row_max;
		cur_sum[qi] = cm_sum<float>(Pmat[qi]);
	}

	// [P * V accumulator]
	// Omat accumulates weighted value vectors for this partition.
	matrix<float, Q_head_chunk_size, HEAD_SIZE/REG_N * REG_M * REG_N> Omat = 0;

	#pragma unroll
	for (uint block_idx = 0, ki = 0; block_idx < block_num; block_idx++) {
		// [Load V]
		// V remains fp16 cache (no TurboQuant in value path).
		uint blk_indices = block_indices[start_block_idx + block_idx];
		uint v_base_offset = blk_indices * per_v_block_element_num + kv_head_num_idx * (per_v_block_element_num / KV_HEADS_NUM);

		lsc::block_2d_desc<half, 1, REG_K, REG_N> b2dV(value + v_base_offset, KV_BLOCK_SIZE - 1, HEAD_SIZE * sizeof(half) - 1, kv_pitch - 1, 0, 0);

		uint kv_pos_end = KV_BLOCK_SIZE;
		if (block_idx == block_num - 1 && leftover_size > 0) {
			kv_pos_end = leftover_size % KV_BLOCK_SIZE;
			if (kv_pos_end == 0) kv_pos_end = KV_BLOCK_SIZE;
		}

		#pragma unroll
		for (int kv_pos = 0; kv_pos < kv_pos_end; kv_pos += REG_K, ki++) {
			#pragma unroll
			for (int k = 0, ri = 0; k < HEAD_SIZE; k += REG_N, ri++) {
				matrix<half, REG_K, REG_N> Vmat = 0;
				b2dV.set_block_x(k);
				cm_load<lsc::VNNI>(Vmat.format<half>(), b2dV.set_block_y(kv_pos));

				#if CLEAN_UNUSED_KVCACHE
				if (kv_pos_end - kv_pos < KV_STEP) {
					auto VmatRef = Vmat.format<half, REG_K/2, REG_N*2>();
					uint valid_rows = kv_pos_end - kv_pos;
					uint valid_rows_vnni = (valid_rows + 1) / 2;
					#pragma unroll
					for (int r = valid_rows_vnni; r < REG_K/2; r++) {
						VmatRef.row(r) = 0.0f;
					}
					if (valid_rows % 2 == 1) {
						VmatRef.row(valid_rows_vnni - 1).select<REG_N, 2>(1) = 0.0f;
					}
				}
				#endif

				matrix<half, Q_head_chunk_size, REG_K> Pmat_data = Pmat.select<Q_head_chunk_size,1,REG_K,1>(0, ki * REG_K);
				auto Omat_data = Omat.select<Q_head_chunk_size,1,REG_N,1>(0, ri * REG_N);
				// [P * V]
				// Use DPAS for weighted value aggregation.
				Omat_data = cm_dpas<CM_PRECISION_HF, CM_PRECISION_HF, SystolicDepth, Q_head_chunk_size>(
							Omat_data.format<float>(),
							Vmat.format<half, REG_K/2, REG_N*2>().format<int32_t>(),
							Pmat_data.format<int32_t>());
			}
		}
	}

	#pragma unroll
	for (int qi = 0; qi < Q_head_chunk_size; qi++) {
		// [Write output]
		// Normalize by partition sum and write partial output/lse for reduce kernel.
		matrix<float, REG_M, REG_N> cur_O_f32;
		uint o_offset = seq_idx * kv_partition_num * HEADS_NUM * HEAD_SIZE + kv_partition_num * (head_num_idx + qi) * HEAD_SIZE + wg_thread_id * HEAD_SIZE;
		auto Omat_slice = Omat[qi].format<float, HEAD_SIZE/REG_N * REG_M, REG_N>();
		#pragma unroll
		for (int k = 0, ri = 0; k < HEAD_SIZE; k += REG_N, ri++) {
			auto cO = Omat_slice[ri].format<float, REG_M, REG_N>();
			cur_O_f32 = cm_div_ieee(cO, cur_sum[qi]);
			cm_svm_block_write<float, REG_N>((svmptr_t)(output + o_offset + k), cur_O_f32.format<float>());
		}
		uint lse_offset = seq_idx * HEADS_NUM * kv_partition_num + (head_num_idx + qi) * kv_partition_num + wg_thread_id;
		lse[lse_offset] = cur_lse[qi];
	}
}

extern "C" _GENX_MAIN_ void cm_sdpa_2nd_reduce(
	float* input [[type("svmptr_t")]],
	half* output [[type("svmptr_t")]],
	float* lse [[type("svmptr_t")]],
	int kv_partition_num
	) {
	auto batch = cm_global_id(0);
	auto head = cm_global_id(1);
	auto offset = cm_group_id(2) * REDUCE_SPLIT_SIZE;
	const int total_partition_num = (kv_partition_num * HEADS_NUM);

	float total_lse = 0.0;
	uint lse_offset = batch * total_partition_num + head * kv_partition_num;
	constexpr float log2e = 1.4426950408889634f;
	float* lse_vec = lse + lse_offset;
	float lse_max = lse_vec[0];
	for (int k = 1; k < kv_partition_num; k++) {
		lse_max = cm_max<float>(lse_vec[k], lse_max);
	}

	int iter = kv_partition_num / 16;
	for (int k = 0; k < iter * 16; k += 16) {
		#pragma unroll
		for (int ki = k; ki < k + 16; ki++) {
			float lse_value = cm_exp<float>((lse_vec[ki] - lse_max) * log2e);
			total_lse += lse_value;
		}
	}
	for (int k = iter * 16; k < kv_partition_num; k++) {
		float lse_value = cm_exp<float>((lse_vec[k] - lse_max) * log2e);
		total_lse += lse_value;
	}

	matrix<half, 1, REDUCE_SPLIT_SIZE> out_mat = 0;
	matrix<float, 1, REDUCE_SPLIT_SIZE> out_mat_f32 = 0;
	matrix<float, 1, REDUCE_SPLIT_SIZE> data_mat;
	uint input_offset = batch * total_partition_num * HEAD_SIZE + head * kv_partition_num * HEAD_SIZE + offset;

	for (int k = 0; k < iter * 16; k += 16) {
		#pragma unroll
		for (int ki = k; ki < k + 16; ki++) {
			cm_svm_block_read<float, REDUCE_SPLIT_SIZE>((svmptr_t)(input + input_offset), data_mat.format<float>());
			input_offset += HEAD_SIZE;
			float lse_value = cm_exp<float>((lse_vec[ki] - lse_max) * log2e);
			out_mat_f32 += cm_mul<float>(data_mat, (float)(lse_value / total_lse));
		}
	}
	for (int k = iter * 16; k < kv_partition_num; k++) {
		cm_svm_block_read<float, REDUCE_SPLIT_SIZE>((svmptr_t)(input + input_offset), data_mat.format<float>());
		input_offset += HEAD_SIZE;
		float lse_value = cm_exp<float>((lse_vec[k] - lse_max) * log2e);
		out_mat_f32 += cm_mul<float>(data_mat, (float)(lse_value / total_lse));
	}

	out_mat = cm_mul<half>(out_mat_f32, (float)1.0f);
	uint output_offset = batch * HEADS_NUM * HEAD_SIZE + head * HEAD_SIZE + offset;
	cm_svm_block_write<half, REDUCE_SPLIT_SIZE>((svmptr_t)(output + output_offset), out_mat.format<half>());
}
